<Window x:Class="ModpackSync.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ModpackSync"
        Width="1280"
        Height="780"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">

            <Grid Margin="16">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Branding -->
                <StackPanel Grid.Row="0"
                            Margin="8,12,8,0">

                    <TextBlock Text="ModpackSync"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <TextBlock Margin="0,5,0,0"
                               Text="Modpack management"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>

                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="2">

                    <Button x:Name="DashboardNavigationButton"
                            Style="{StaticResource NavigationButtonStyle}"
                            Background="#344638"
                            Foreground="{StaticResource TextBrush}"
                            Content="⌂   Dashboard"
                            Click="DashboardNavigationButton_Click"/>

                    <Button x:Name="VersionsNavigationButton"
                            Margin="0,6,0,0"
                            Style="{StaticResource NavigationButtonStyle}"
                            Content="▣   Versions"
                            Click="VersionsNavigationButton_Click"/>

                    <Button Margin="0,6,0,0"
                            Style="{StaticResource NavigationButtonStyle}"
                            Content="☁   Server"
                            IsEnabled="False"/>

                    <Button x:Name="SettingsNavigationButton"
                            Margin="0,6,0,0"
                            Style="{StaticResource NavigationButtonStyle}"
                            Content="⚙   Settings"
                            Click="SettingsNavigationButton_Click"/>

                </StackPanel>

                <!-- Server status -->
                <Border Grid.Row="3"
                        Padding="12"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">

                    <StackPanel>

                        <TextBlock Text="Server"
                                   FontWeight="SemiBold"/>

                        <StackPanel Margin="0,8,0,0"
                                    Orientation="Horizontal">

                            <Ellipse x:Name="ServerStatusEllipse"
                                 Width="8"
                                 Height="8"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 Fill="{StaticResource WarningBrush}"/>

                                                    <TextBlock x:Name="ServerStatusTextBlock"
                                   Text="Not connected"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>

                        </StackPanel>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

        <!-- Page content -->
        <ContentControl x:Name="MainContentHost"
                        Grid.Column="1"/>

    </Grid>

</Window>