<UserControl x:Class="ModpackSync.Desktop.Views.ServerBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="28">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <TextBlock Text="Server"
                           FontSize="30"
                           FontWeight="Bold"/>

                <TextBlock Margin="0,5,0,0"
                           Text="Browse modpacks and versions stored on the server."
                           FontSize="13"
                           Foreground="{StaticResource SecondaryTextBrush}"/>

            </StackPanel>

            <!-- Search -->
            <Grid Grid.Column="2"
                  VerticalAlignment="Center">

                <TextBox x:Name="ServerSearchTextBox"
                         Height="38"
                         Padding="12,0,36,0"
                         VerticalContentAlignment="Center"
                         ToolTip="Search server packs"
                         TextChanged="ServerSearchTextBox_TextChanged"/>

                <TextBlock x:Name="SearchPlaceholderTextBlock"
                           Margin="13,0,38,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Text="Search server packs..."
                           FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}"/>

                <Button x:Name="ClearSearchButton"
                        Width="28"
                        Height="28"
                        Margin="0,0,4,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        Content="×"
                        FontSize="18"
                        ToolTip="Clear search"
                        Visibility="Collapsed"
                        Click="ClearSearchButton_Click"/>

            </Grid>

            <Button x:Name="RefreshButton"
                    Grid.Column="4"
                    MinWidth="110"
                    Height="38"
                    VerticalAlignment="Center"
                    Style="{StaticResource StandardButtonStyle}"
                    Content="Refresh"
                    Click="RefreshButton_Click"/>

        </Grid>

        <!-- Browser -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Server packs -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="18,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="Server packs"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <Border Margin="10,0,0,0"
                                    Padding="8,3"
                                    VerticalAlignment="Center"
                                    Background="#29342B"
                                    CornerRadius="10">

                                <TextBlock Text="{Binding ElementName=PacksDataGrid,
                                                        Path=Items.Count}"
                                           FontSize="11"
                                           Foreground="{StaticResource PrimaryHoverBrush}"/>

                            </Border>

                        </StackPanel>

                    </Grid>

                    <DataGrid x:Name="PacksDataGrid"
                              Grid.Row="1"
                              IsReadOnly="True"
                              AlternationCount="2"
                              SelectionChanged="PacksDataGrid_SelectionChanged">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Pack"
                                                Binding="{Binding Name}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Versions"
                                                Binding="{Binding VersionCount}"
                                                Width="90"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

            <!-- Versions -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="18,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="Versions"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <Border Margin="10,0,0,0"
                                    Padding="8,3"
                                    VerticalAlignment="Center"
                                    Background="#29342B"
                                    CornerRadius="10">

                                <TextBlock Text="{Binding ElementName=VersionsDataGrid,
                                                        Path=Items.Count}"
                                           FontSize="11"
                                           Foreground="{StaticResource PrimaryHoverBrush}"/>

                            </Border>

                        </StackPanel>

                        <TextBlock x:Name="SelectedPackTextBlock"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Text="Select a pack"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>

                    </Grid>

                    <DataGrid x:Name="VersionsDataGrid"
                              Grid.Row="1"
                              IsReadOnly="True"
                              AlternationCount="2"
                              SelectionChanged="VersionsDataGrid_SelectionChanged">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Version"
                                                Binding="{Binding VersionLabel}"
                                                Width="1.2*"/>

                            <DataGridTextColumn Header="Created"
                                                Binding="{Binding CreatedAt,
                                                                  StringFormat={}{0:dd MMM yyyy HH:mm}}"
                                                Width="1.6*"/>

                            <DataGridTemplateColumn Header="Status"
                                                    Width="120">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <Border Padding="9,4"
                                                HorizontalAlignment="Left"
                                                Background="#29342B"
                                                CornerRadius="10">

                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryHoverBrush}"/>

                                        </Border>

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Files"
                                                Binding="{Binding FileCount}"
                                                Width="70"/>

                            <DataGridTextColumn Header="Release notes"
                                                Binding="{Binding ReleaseNotes}"
                                                Width="2*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

        </Grid>

        <!-- Actions -->
        <StackPanel Grid.Row="4"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

            <Button x:Name="CopyArchiveUrlButton"
                    MinWidth="145"
                    Height="40"
                    Margin="0,0,10,0"
                    Style="{StaticResource StandardButtonStyle}"
                    Content="Copy Archive URL"
                    Click="CopyArchiveUrlButton_Click"/>

            <Button x:Name="DownloadVersionButton"
                    MinWidth="145"
                    Height="40"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Download Version"
                    Click="DownloadVersionButton_Click"/>

        </StackPanel>

        <!-- Status -->
        <Border Grid.Row="6"
                Padding="13,10"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0"
                         Width="8"
                         Height="8"
                         VerticalAlignment="Center"
                         Fill="{StaticResource PrimaryBrush}"/>

                <TextBlock x:Name="StatusTextBlock"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Text="Ready."
                           FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap"/>

                <ProgressBar x:Name="OperationProgressBar"
                             Grid.Column="4"
                             Height="12"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             Visibility="Collapsed"/>

            </Grid>

        </Border>

    </Grid>

</UserControl>