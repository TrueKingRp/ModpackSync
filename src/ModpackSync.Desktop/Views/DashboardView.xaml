<UserControl x:Class="ModpackSync.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="28">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock Text="Dashboard"
                           FontSize="30"
                           FontWeight="Bold"/>

                <TextBlock Margin="0,5,0,0"
                           Text="Manage your local Prism Launcher modpacks."
                           FontSize="13"
                           Foreground="{StaticResource SecondaryTextBrush}"/>

            </StackPanel>

            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    MinWidth="110"
                    Height="38"
                    Style="{StaticResource StandardButtonStyle}"
                    Content="Refresh"
                    Click="RefreshButton_Click"/>

        </Grid>

        <!-- Instances folder -->
        <Border Grid.Row="2"
                Padding="18"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock Text="Prism Launcher instances folder"
                               FontSize="14"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="InstancesDirectoryTextBox"
                             Margin="0,10,0,0"
                             Height="38"
                             IsReadOnly="True"/>

                </StackPanel>

                <Button x:Name="BrowseButton"
                        Grid.Column="2"
                        MinWidth="110"
                        Height="38"
                        Margin="0,31,0,0"
                        VerticalAlignment="Top"
                        Style="{StaticResource StandardButtonStyle}"
                        Content="Browse..."
                        Click="BrowseButton_Click"/>

            </Grid>

        </Border>

        <!-- Pack table -->
        <Border Grid.Row="4"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                ClipToBounds="True">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="18,15">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="Discovered packs"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <Border Margin="10,0,0,0"
                                Padding="8,3"
                                VerticalAlignment="Center"
                                Background="#29342B"
                                CornerRadius="10">

                            <TextBlock Text="{Binding ElementName=InstancesDataGrid,
                                                    Path=Items.Count}"
                                       FontSize="11"
                                       Foreground="{StaticResource PrimaryHoverBrush}"/>

                        </Border>

                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="Select a pack to manage it"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>

                </Grid>

                <DataGrid x:Name="InstancesDataGrid"
                          Grid.Row="1"
                          IsReadOnly="True"
                          AlternationCount="2"
                          SelectionChanged="InstancesDataGrid_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Pack"
                                            Binding="{Binding Name}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="Minecraft folder"
                                            Binding="{Binding MinecraftPath}"
                                            Width="4*"/>

                        <DataGridTemplateColumn Header="Status"
                                                Width="150">

                            <DataGridTemplateColumn.CellTemplate>

                                <DataTemplate>

                                    <Border Padding="9,4"
                                            HorizontalAlignment="Left"
                                            Background="#29342B"
                                            CornerRadius="10">

                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryHoverBrush}"/>

                                    </Border>

                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

        <!-- Actions -->
        <Grid Grid.Row="6">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="ManagePackButton"
                    Grid.Column="0"
                    MinWidth="120"
                    Height="40"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Manage Pack"
                    IsEnabled="False"
                    Click="ManagePackButton_Click"/>

            <Button x:Name="ScanPackButton"
                    Grid.Column="2"
                    MinWidth="100"
                    Height="40"
                    Style="{StaticResource StandardButtonStyle}"
                    Content="Scan"
                    IsEnabled="False"
                    Click="ScanPackButton_Click"/>

            <Button x:Name="CreateVersionButton"
                    Grid.Column="4"
                    MinWidth="130"
                    Height="40"
                    Style="{StaticResource StandardButtonStyle}"
                    Content="Create Version"
                    IsEnabled="False"
                    Click="CreateVersionButton_Click"/>

            <Button x:Name="ViewVersionsButton"
                    Grid.Column="6"
                    MinWidth="120"
                    Height="40"
                    Style="{StaticResource StandardButtonStyle}"
                    Content="View Versions"
                    IsEnabled="False"
                    Click="ViewVersionsButton_Click"/>

            <Button x:Name="DownloadButton"
                    Grid.Column="8"
                    MinWidth="105"
                    Height="40"
                    Style="{StaticResource StandardButtonStyle}"
                    Content="Download"
                    IsEnabled="False"
                    Click="DownloadButton_Click"/>

            <Button x:Name="UploadButton"
                    Grid.Column="10"
                    MinWidth="105"
                    Height="40"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Upload"
                    IsEnabled="False"
                    Click="UploadButton_Click"/>

        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="8"
                Padding="13,10"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0"
                         Width="8"
                         Height="8"
                         VerticalAlignment="Center"
                         Fill="{StaticResource PrimaryBrush}"/>

                <TextBlock x:Name="StatusTextBlock"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Text="Ready."
                           FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap"/>

            </Grid>

        </Border>

    </Grid>

</UserControl>