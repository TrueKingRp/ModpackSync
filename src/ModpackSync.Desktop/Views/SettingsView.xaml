<UserControl x:Class="ModpackSync.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="28">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">

            <TextBlock Text="Settings"
                       FontSize="30"
                       FontWeight="Bold"/>

            <TextBlock Margin="0,5,0,0"
                       Text="Configure the ModpackSync server connection."
                       FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}"/>

        </StackPanel>

        <!-- Server settings -->
        <Border Grid.Row="2"
                MaxWidth="760"
                HorizontalAlignment="Left"
                Padding="22"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="22"/>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="22"/>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Server URL"
                           FontSize="13"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="ServerUrlTextBox"
                         Grid.Row="2"
                         Width="620"
                         Height="40"
                         HorizontalAlignment="Left"
                         TextChanged="SettingsField_Changed"/>

                <TextBlock Grid.Row="4"
                           Text="API key"
                           FontSize="13"
                           FontWeight="SemiBold"/>

                <PasswordBox x:Name="ApiKeyPasswordBox"
                             Grid.Row="6"
                             Width="620"
                             Height="40"
                             HorizontalAlignment="Left"
                             PasswordChanged="ApiKeyPasswordBox_PasswordChanged"/>

                <TextBlock Grid.Row="8"
                           Text="The API key is stored locally on this computer."
                           FontSize="11"
                           Foreground="{StaticResource SecondaryTextBrush}"/>

                <Grid Grid.Row="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="SaveButton"
                            Grid.Column="0"
                            MinWidth="110"
                            Height="40"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Save"
                            IsEnabled="False"
                            Click="SaveButton_Click"/>

                    <Button x:Name="TestConnectionButton"
                            Grid.Column="2"
                            MinWidth="150"
                            Height="40"
                            Style="{StaticResource StandardButtonStyle}"
                            Content="Test Connection"
                            Click="TestConnectionButton_Click"/>

                </Grid>

                <Border Grid.Row="12"
                        Padding="13,10"
                        Background="{StaticResource ControlBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Ellipse x:Name="ConnectionStatusEllipse"
                                 Grid.Column="0"
                                 Width="8"
                                 Height="8"
                                 VerticalAlignment="Center"
                                 Fill="{StaticResource WarningBrush}"/>

                        <TextBlock x:Name="StatusTextBlock"
                                   Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Text="Connection has not been tested."
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>

                    </Grid>

                </Border>

            </Grid>

        </Border>

        <TextBlock Grid.Row="4"
                   MaxWidth="760"
                   HorizontalAlignment="Left"
                   Text="Publishing and downloading will use this connection in a later step."
                   FontSize="12"
                   Foreground="{StaticResource SecondaryTextBrush}"/>

    </Grid>

</UserControl>