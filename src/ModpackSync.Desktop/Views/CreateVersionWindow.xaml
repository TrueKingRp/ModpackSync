<Window x:Class="ModpackSync.Desktop.Views.CreateVersionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Version"
        Width="560"
        Height="470"
        MinWidth="500"
        MinHeight="420"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">

            <TextBlock Text="Create Version"
                       FontSize="26"
                       FontWeight="Bold"/>

            <TextBlock x:Name="PackNameTextBlock"
                       Margin="0,6,0,0"
                       FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       TextWrapping="Wrap"/>

        </StackPanel>

        <!-- Form -->
        <Border Grid.Row="2"
                Padding="20"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Version label -->
                <TextBlock Grid.Row="0"
                           Text="Version label"
                           FontSize="13"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="VersionLabelTextBox"
                         Grid.Row="2"
                         Height="40"
                         Text="1.0.0"
                         MaxLength="100"
                         TextChanged="VersionLabelTextBox_TextChanged"/>

                <TextBlock Grid.Row="4"
                           Text="Examples: 1.0.0, 1.2.3-beta, 2026.07"
                           FontSize="11"
                           Foreground="{StaticResource SecondaryTextBrush}"/>

                <!-- Release notes -->
                <TextBlock Grid.Row="6"
                           Text="Release notes"
                           FontSize="13"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="ReleaseNotesTextBox"
                         Grid.Row="8"
                         MinHeight="130"
                         Padding="10"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         MaxLength="4000"/>

            </Grid>

        </Border>

        <!-- Footer -->
        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="ValidationTextBlock"
                       Grid.Column="0"
                       Margin="0,0,16,0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource ErrorBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"/>

            <Button Grid.Column="1"
                    Width="100"
                    Height="40"
                    Style="{StaticResource StandardButtonStyle}"
                    Content="Cancel"
                    IsCancel="True"/>

            <Button x:Name="CreateButton"
                    Grid.Column="3"
                    Width="110"
                    Height="40"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Create"
                    IsDefault="True"
                    Click="CreateButton_Click"/>

        </Grid>

    </Grid>

</Window>